{
  "name": "vechain-ai",
  "version": "0.1.0",
  "private": true,
  "description": "VeChain AI monorepo — plugins, agents, and tools for AI-assisted VeChain development",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#.git'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npx nx run vechain-dev:validate",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "markdownlint-cli2": "^0.17.2",
    "nx": "^20.4.4",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
