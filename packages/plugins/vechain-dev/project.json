{
  "name": "vechain-dev",
  "root": "packages/plugins/vechain-dev",
  "targets": {
    "lint-markdown": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx markdownlint-cli2 'packages/plugins/vechain-dev/**/*.md'",
        "cwd": "{workspaceRoot}"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/validate-plugin.cjs packages/plugins/vechain-dev",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
