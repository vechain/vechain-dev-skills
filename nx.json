{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc*", "{workspaceRoot}/eslint.config.*"]
    },
    "lint-markdown": {
      "inputs": ["default", "{workspaceRoot}/.markdownlint-cli2.*"]
    },
    "validate": {
      "inputs": ["default"]
    }
  },
  "defaultBase": "main"
}
